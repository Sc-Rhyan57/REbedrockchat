<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_arrow_back"
        android:tint="@color/white"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_xbox"
        android:tint="@color/xbox_green"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrar com Xbox"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Faça login com sua conta Microsoft para entrar nos servidores."
        android:textColor="@color/gray_400"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnStartLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Iniciar Login"
        android:backgroundTint="@color/xbox_green"
        android:layout_marginBottom="24dp" />

    <ProgressBar
        android:id="@+id/progressLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/layoutCodeInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Acesse o link abaixo:"
            android:textColor="@color/gray_300"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvVerificationUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="https://microsoft.com/link"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Insira o código (toque para copiar):"
            android:textColor="@color/gray_300"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvUserCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XXXXXXXX"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:background="@drawable/bg_code_block"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnOpenBrowser"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="Abrir navegador" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatusLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/gray_400"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingTop="16dp" />

</LinearLayout>
